        companyName: "Eco Pneus Reciclagem Ltda",
        name: "Eco Pneus Reciclagem Ltda",
        email: "contato@ecopneus.com.br",
        phone: "(65) 3333-2211",
        createdAt: "2026-01-14",
        status: "Ativa",
        sustainableLevel: "Bronze",
        totalCollections: 0,
        lastCollection: "",
        password: "123456",
        photo: "",
        googlePhoto: "",
        cnpj: "12.345.678/0001-99",
        address: "Av. Industrial, 800 - Distrito Verde",
        city: "Cuiabá",
        state: "MT"
      }
